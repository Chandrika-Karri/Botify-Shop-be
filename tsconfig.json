{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2020",

    "types": ["node", "express", "jest"],

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,

    "sourceMap": true
  },
  "include": ["src", "src/scripts"]
}
